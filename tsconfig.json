{
  "compilerOptions": {
    "outDir": ".tsc-outDir",
    "declaration": true,
    "emitDeclarationOnly": true,
    "module": "esnext",
    "target": "esnext",
    "esModuleInterop": true,
    "sourceMap": false,
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "strictNullChecks": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "jsx": "react",
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
    "paths": {
      "alak/*": [
        "packages/alak/src/*"
      ],
      "@alaq/atom": [
        "packages/atom/src/index.ts"
      ],
      "@alaq/atom/*": [
        "packages/atom/src/*"
      ],
      "@alaq/quark": [
        "packages/quark/src/index.ts"
      ],
      "@alaq/quark/*": [
        "packages/quark/src/*"
      ],
      "@alaq/deep-state": [
        "packages/deep-state/src/index.ts"
      ],
      "@alaq/deep-state/*": [
        "packages/deep-state/src/*"
      ],
      "@alaq/graph": [
        "packages/graph/src/index.ts"
      ],
      "@alaq/graph/*": [
        "packages/graph/src/*"
      ],
      "@alaq/mcp": [
        "packages/mcp/src/index.ts"
      ],
      "@alaq/mcp/*": [
        "packages/mcp/src/*"
      ],
      "@alaq/nucl": [
        "packages/nucl/src/index.ts"
      ],
      "@alaq/nucl/*": [
        "packages/nucl/src/*"
      ],
      "@alaq/bitmask/*": [
        "packages/bitmask/src/*"
      ],
      "@alaq/datastruct/*": [
        "packages/datastruct/src/*"
      ],
      "@alaq/rune/*": [
        "packages/rune/src/*"
      ],
      "@alaq/fx": [
        "packages/fx/src/index.ts"
      ],
      "@alaq/fx/*": [
        "packages/fx/src/*"
      ],
      "@alaq/flex": [
        "packages/flex/src/index.ts"
      ],
      "@alaq/flex/*": [
        "packages/flex/src/*"
      ],
      "@alaq/link": [
        "packages/link/src/index.ts"
      ],
      "@alaq/link/*": [
        "packages/link/src/*"
      ],
      "@alaq/link-state": [
        "packages/link-state/src/index.ts"
      ],
      "@alaq/link-state/*": [
        "packages/link-state/src/*"
      ],
      "@alaq/link-state-vue": [
        "packages/link-state-vue/src/index.ts"
      ],
      "@alaq/link-state-vue/*": [
        "packages/link-state-vue/src/*"
      ],
      "@alaq/plugin-logi": [
        "packages/plugin-logi/src/index.ts"
      ],
      "@alaq/plugin-logi/*": [
        "packages/plugin-logi/src/*"
      ],
      "~/scripts/*": [
        "scripts/*"
      ]
    },
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext",
      "WebWorker"
    ],
    "types": [
      "@types/node",
      "@types/bun",
      "typescript"
    ]
  },
  "include": [
    "packages/flex/src/jsx.d.ts",
    "packages/**/*.ts",
    "scripts/**/*.d.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "artifacts"
  ],
  "ts-node": {
    "transpileOnly": true,
    "require": [
      "tsconfig-paths/register"
    ],
    "compilerOptions": {
      "module": "CommonJS"
    }
  }
}
