{
  "compilerOptions": {
    //    "lib": ["ES2017", "DOM"],
    "module": "commonjs",
    "target": "ES2018",
    "outDir": "dist",
    "declaration": true,
    "esModuleInterop": true,
    "sourceMap": false,
    "rootDir": ".",
    "baseUrl": ".",

    "paths": {
      //      "@la/*": ["packages/*/core"],
      "alak": ["packages/"]
    },
    "types": ["node"],
    "typeRoots": [
      "packages/alak/index.d.ts",
      "packages/alak/IAtomConstructor.d.ts",
      "packages/alak/ComputeStrategy.d.ts",
      "packages/alak/IAtom.d.ts",
      "packages/global.d.ts"
    ]
  },
  "include": [
    "packages/global.d.ts",
    "packages/*/*.d.ts",
    "packages/*/src/*.ts",
    "packages/*/__tests__"
  ]
}
