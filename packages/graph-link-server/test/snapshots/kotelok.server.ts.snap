/**
 * Ambient context passed to every action handler. Implementations live
 * outside the generator — usually a thin adapter around
 * createLinkServer() that captures the peer map and codec.
 *
 * v0.1: no CRDT helpers, no request/reply timeout. See TODO.
 */
export interface ActionContext<TPeerId = string> {
  /** The peer who originated this action. Set by the dispatcher. */
  readonly peerId: TPeerId

  /**
   * Broadcast a raw (type, payload) message to every peer whose metadata
   * puts them in the given scope id. Pass excludeSelf=true to skip the
   * originator — useful for "notify others" style echoes.
   */
  broadcastToRoom(
    roomId: string,
    type: number,
    payload: unknown,
    excludeSelf?: boolean,
  ): void

  /** Send a direct message to one peer by id. No-op if the peer is gone. */
  sendTo(peerId: TPeerId, type: number, payload: unknown): void

  /** Iterate connected peer ids. Snapshot at call time — don't retain. */
  peers(): Iterable<TPeerId>
}

