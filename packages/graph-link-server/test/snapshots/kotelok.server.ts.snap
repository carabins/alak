// ────────────────────────────────────────────────────────────────
// Dispatcher — plug into createLinkServer({ onAction })
// ────────────────────────────────────────────────────────────────

export interface DispatcherOptions {
  /** Handler table. One method per action in the SDL. */
  handlers: ActionHandlers
  /** Base context. The dispatcher shallow-overrides `peerId` per call. */
  ctx: Omit<ActionContext, 'peerId'> & { peerId?: string }
  /** Called when no handler matches. Default: throw. */
  onUnknownAction?: (action: string, path: string) => unknown
  /** Called when a handler throws. Default: rethrow. */
  onError?: (action: string, error: unknown) => unknown
}

/**
 * Strip the "${scope}." prefix from a wire path. Returns the raw
 * path when the prefix does not match — the handler will likely
 * treat that as invalid and throw, but we stay permissive so a
 * misrouted message can't crash the server.
 */
function extractScopeId(path: string, scope: string): string {
  const prefix = scope + '.'
  return path.startsWith(prefix) ? path.slice(prefix.length) : path
}

/**
 * Wire generated handlers to createLinkServer()'s onAction callback.
 *
 * Usage:
 *   const server = createLinkServer({
 *     port: 3456,
 *     onAction: createActionDispatcher({ handlers, ctx }),
 *   })
 */
export function createActionDispatcher(options: DispatcherOptions) {
  return async (
    action: string,
    path: string,
    args: unknown,
    peerId: string,
  ): Promise<unknown> => {
    const peerCtx: ActionContext = { ...options.ctx, peerId }
    try {
      switch (action) {
        case 'ConfirmRound': {
          const scopeId = extractScopeId(path, 'room')
          return await options.handlers.confirmRound(peerCtx, scopeId)
        }
        case 'CreateRoom': {
          const input = args as { settings?: IGameSettings }
          return await options.handlers.createRoom(peerCtx, input)
        }
        case 'CreateTeam': {
          const scopeId = extractScopeId(path, 'room')
          const input = args as { name: string }
          return await options.handlers.createTeam(peerCtx, scopeId, input)
        }
        case 'FixScore': {
          const scopeId = extractScopeId(path, 'room')
          const input = args as { word: string; outcome: WordOutcome }
          return await options.handlers.fixScore(peerCtx, scopeId, input)
        }
        case 'GuessWord': {
          const scopeId = extractScopeId(path, 'room')
          return await options.handlers.guessWord(peerCtx, scopeId)
        }
        case 'JoinRoom': {
          const scopeId = extractScopeId(path, 'room')
          const input = args as { name: string }
          return await options.handlers.joinRoom(peerCtx, scopeId, input)
        }
        case 'JoinTeam': {
          const scopeId = extractScopeId(path, 'room')
          const input = args as { teamId: string }
          return await options.handlers.joinTeam(peerCtx, scopeId, input)
        }
        case 'PlayerReady': {
          const scopeId = extractScopeId(path, 'room')
          return await options.handlers.playerReady(peerCtx, scopeId)
        }
        case 'SkipWord': {
          const scopeId = extractScopeId(path, 'room')
          return await options.handlers.skipWord(peerCtx, scopeId)
        }
        case 'StartGame': {
          const scopeId = extractScopeId(path, 'room')
          return await options.handlers.startGame(peerCtx, scopeId)
        }
        case 'SubmitWords': {
          const scopeId = extractScopeId(path, 'room')
          const input = args as { words: string[] }
          return await options.handlers.submitWords(peerCtx, scopeId, input)
        }
        default: {
          if (options.onUnknownAction) return options.onUnknownAction(action, path)
          throw new Error(`[dispatcher] unknown action: ${action}`)
        }
      }
    } catch (err) {
      if (options.onError) return options.onError(action, err)
      throw err
    }
  }
}

