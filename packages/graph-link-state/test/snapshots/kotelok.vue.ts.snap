  readonly $meta: { readonly isGhost: boolean; readonly path: string }
  $release(): void

  // Reactive field nodes
  readonly $id: ISyncNode<string>
  // (renamed from $status — collides with runtime facade)
  readonly $statusField: ISyncNode<RoomStatus>
  readonly $settings: GameSettingsNode
  readonly $players: SyncListNode<IPlayer, PlayerNode>
  readonly $teams: SyncListNode<ITeam, TeamNode>
