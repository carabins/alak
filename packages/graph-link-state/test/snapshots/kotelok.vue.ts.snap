// ────────────────────────────────────────────────────────────────
// CRDT schema (SyncBridge)
// ────────────────────────────────────────────────────────────────

// CRDT schema — derived from @crdt / @sync directives. Paths use '*'
// wildcards for scope-bound ids (e.g. 'room.*.id' matches 'room.abc.id').
// REALTIME fields are intentionally omitted — they travel out-of-band as
// datagrams and are never stored in the CRDT.
export const kotelokSchema: Record<string, FieldSchema> = {
  'room.*.id': { type: 'lww' },
  'room.*.status': { type: 'lww' },
  'room.*.settings.wordsPerPlayer': { type: 'lww' },
  'room.*.settings.roundTime': { type: 'lww' },
  'room.*.players': { type: 'or-set' },
  'room.*.players.*.id': { type: 'lww' },
  'room.*.players.*.name': { type: 'lww' },
  'room.*.players.*.avatar': { type: 'lww' },
  'room.*.players.*.myWords': { type: 'or-set' },
  'room.*.players.*.myWords.*': { type: 'lww' },
  'room.*.teams': { type: 'or-set' },
  'room.*.teams.*.id': { type: 'lww' },
  'room.*.teams.*.name': { type: 'lww' },
  'room.*.teams.*.score': { type: 'lww' },
  'room.*.teams.*.memberIds': { type: 'or-set' },
  'room.*.teams.*.memberIds.*': { type: 'lww' },
