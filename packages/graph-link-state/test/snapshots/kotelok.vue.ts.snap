// SDL: enum RoomStatus { LOBBY, GAME_ACTIVE, FINISHED }
export enum RoomStatus {
  LOBBY = 'LOBBY',
  GAME_ACTIVE = 'GAME_ACTIVE',
  FINISHED = 'FINISHED',
}

// SDL: enum RoundPhase { PREPARE, ACTIVE, REVIEW }
export enum RoundPhase {
  PREPARE = 'PREPARE',
  ACTIVE = 'ACTIVE',
  REVIEW = 'REVIEW',
}

// SDL: enum WordOutcome { GUESSED, SKIPPED }
