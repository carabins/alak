export interface UseGameRoomResult {
  node: GameRoomNode
  value: Ref<IGameRoom | undefined>
  status: Ref<'pending' | 'ready' | 'error' | undefined>
}

export function useGameRoom(store: SyncStore, id: string): UseGameRoomResult {
  const node = createGameRoomNode(store, id)
  return {
    node,
    value: useNode(node.$node),
    status: useNode(node.$status as unknown as ISyncNode<'pending' | 'ready' | 'error'>),
  }
}

export function useGameRoomInScope(id: string): UseGameRoomResult {
  return useGameRoom(useStore(), id)
}

