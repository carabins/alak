  confirmRound(): Promise<boolean>
  fixScore(input: { word: string, outcome: WordOutcome }): Promise<boolean>
}

// @scope(name: "room") @sync(qos: RELIABLE)
export function createGameRoomNode(store: SyncStore, id: string): GameRoomNode {
  const path = `room.${id}`
  const base = store.get(path) as ISyncNode<IGameRoom>
  return {
    $node: base,
    get value() { return base.value as IGameRoom | undefined },
    get $status() { return base.$status },
    get $meta() { return base.$meta },
    $release() { base.$release() },

    get $id(): ISyncNode<string> { return base._node('id') },
    get $statusField(): ISyncNode<RoomStatus> { return base._node('status') },
    get $settings(): GameSettingsNode { return createGameSettingsNode(store, path + '.settings') },
    get $players(): SyncListNode<IPlayer, PlayerNode> { return createListNode(store, path + '.players', (p0) => createPlayerNode(store, p0)) },
    get $teams(): SyncListNode<ITeam, TeamNode> { return createListNode(store, path + '.teams', (p0) => createTeamNode(store, p0)) },
    get $wordSubmissions(): SyncListNode<IWordSubmission, WordSubmissionNode> { return createListNode(store, path + '.wordSubmissions', (p0) => createWordSubmissionNode(store, p0)) },
    get $totalWordsCount(): ISyncNode<number> { return base._node('totalWordsCount') },
    get $currentRound(): RoundStateNode { return createRoundStateNode(store, path + '.currentRound') },
    get $currentTeamId(): ISyncNode<string | undefined> { return base._node('currentTeamId') },

    get id(): string { return base._get('id') as string },
    get status(): RoomStatus { return base._get('status') as RoomStatus },
    get settings(): IGameSettings { return base._get('settings') as IGameSettings },
    get players(): IPlayer[] { return base._get('players') as IPlayer[] },
    get teams(): ITeam[] { return base._get('teams') as ITeam[] },
    get wordSubmissions(): IWordSubmission[] { return base._get('wordSubmissions') as IWordSubmission[] },
    get totalWordsCount(): number { return base._get('totalWordsCount') as number },
    get currentRound(): IRoundState | undefined { return base._get('currentRound') as IRoundState | undefined },
    get currentTeamId(): string | undefined { return base._get('currentTeamId') as string | undefined },

    joinRoom: (input: { name: string }): Promise<IPlayer> => base._act('JoinRoom', input) as Promise<IPlayer>,
    createTeam: (input: { name: string }): Promise<ITeam> => base._act('CreateTeam', input) as Promise<ITeam>,
    joinTeam: (input: { teamId: string }): Promise<boolean> => base._act('JoinTeam', input) as Promise<boolean>,
    submitWords: (input: { words: string[] }): Promise<boolean> => base._act('SubmitWords', input) as Promise<boolean>,
    startGame: (): Promise<void> => base._act('StartGame', undefined) as Promise<void>,
    playerReady: (): Promise<boolean> => base._act('PlayerReady', undefined) as Promise<boolean>,
    guessWord: (): Promise<boolean> => base._act('GuessWord', undefined) as Promise<boolean>,
    skipWord: (): Promise<boolean> => base._act('SkipWord', undefined) as Promise<boolean>,
    confirmRound: (): Promise<boolean> => base._act('ConfirmRound', undefined) as Promise<boolean>,
    fixScore: (input: { word: string, outcome: WordOutcome }): Promise<boolean> => base._act('FixScore', input) as Promise<boolean>,
  }
}

