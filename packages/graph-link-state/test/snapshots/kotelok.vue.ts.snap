// ────────────────────────────────────────────────────────────────
// Unscoped actions
// ────────────────────────────────────────────────────────────────

// SDL: action CreateRoom (unscoped)
export async function createRoom(store: SyncStore, input: { settings?: IGameSettings }): Promise<string> {
  const onAction = (store as any).options?.onAction
  if (!onAction) {
    console.warn('No onAction handler in SyncStore for CreateRoom')
    return undefined as unknown as string
  }
  return onAction('CreateRoom', '', input) as Promise<string>
}

// ────────────────────────────────────────────────────────────────
// Root API
// ────────────────────────────────────────────────────────────────

export function createApi(store: SyncStore) {
  return {
    state: {
      room: (id: string) => createGameRoomNode(store, id),
      gameSettings: (path: string = 'gameSettings') => createGameSettingsNode(store, path),
      player: (path: string = 'player') => createPlayerNode(store, path),
      roundState: (path: string = 'roundState') => createRoundStateNode(store, path),
      roundStats: (path: string = 'roundStats') => createRoundStatsNode(store, path),
      systemInfo: (path: string = 'systemInfo') => createSystemInfoNode(store, path),
      team: (path: string = 'team') => createTeamNode(store, path),
      wordSubmission: (path: string = 'wordSubmission') => createWordSubmissionNode(store, path),
    },
    actions: {
      createRoom: (input: Parameters<typeof createRoom>[1]) => createRoom(store, input),
    },
  }
}

