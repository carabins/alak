// SDL: action StartGame (scope: "room", fire-forget)
pub fn start_game_topic(namespace: &str, id: &str) -> String {
    format!("{}/room/{}/action/StartGame", namespace, id)
}

/// Invoke the `StartGame` action over zenoh.
/// Fire-forget: publishes to the action topic without waiting for a reply.
pub async fn call_start_game(
    session: &Session,
    namespace: &str,
    id: &str,
) -> zenoh::Result<()> {
    let key = start_game_topic(namespace, id);
    let payload: Vec<u8> = Vec::new();
    session.put(&key, payload).res().await?;
    Ok(())
}

